# ─── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/authplatform"

# ─── Authentication ────────────────────────────────────────────
# JWT secret key (required - must be a strong random string in production)
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-strong-random-secret-in-production"

# Access token expiry (default: 7d, extended with Remember Me: 30d)
AUTH_EXPIRES_IN="7d"

# Refresh token expiry (default: 30d, extended with Remember Me: 90d)
REFRESH_TOKEN_EXPIRES_IN="30d"

# ─── Application ──────────────────────────────────────────────
# Public URL of the application (required for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application name (displayed in UI)
NEXT_PUBLIC_APP_NAME="AuthPlatform"

# ─── Cloudinary ────────────────────────────────────────────────
# Cloudinary cloud name (required for profile image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Cloudinary API key (required for profile image uploads)
CLOUDINARY_API_KEY="your-api-key"

# Cloudinary API secret (required for profile image uploads)
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Node Environment ─────────────────────────────────────────
# Set to "production" for deployment (enables secure cookies, etc.)
NODE_ENV="development"

# ─── Docker ────────────────────────────────────────────────────
# These vars are used by docker-compose.yml and can be set in a .env
# file next to docker-compose.yml before running docker compose up.
#
# AUTH_SECRET must be a strong random string in production.
# Generate with: openssl rand -base64 32
# AUTH_SECRET="change-me-to-a-strong-random-secret-in-production"
#
# Cloudinary credentials (required for profile image uploads)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"